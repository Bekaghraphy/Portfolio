# ─── Animation Video Automation Pipeline — Environment Variables ───────────────
# Copy this file to .env and fill in your API keys
# NEVER commit .env to git

# Claude API (script generation)
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs (voice-over — leave empty to use gTTS fallback)
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # default: Rachel

# OpenAI / DALL-E 3 (scene image generation)
OPENAI_API_KEY=sk-...

# YouTube Data API v3
# Download client_secrets.json from Google Cloud Console → Credentials → OAuth 2.0
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
